# Copy values from Vue root .env.local (VUE_APP_FIREBASE_*)
# into src/environments/environment.ts → firebase: { ... }

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Optional — Pexels stock search for Stock Looks prototype
# https://www.pexels.com/api/
# Put into environment.ts → pexelsApiKey
PEXELS_API_KEY=
